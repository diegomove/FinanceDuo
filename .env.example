# Generate a strong secret key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Optional: set to 1 only when app is served over HTTPS
SESSION_COOKIE_SECURE=0

# Optional: initial password used by init_db.py (random if omitted)
DEFAULT_PASSWORD=change-me-on-first-run

# Names displayed in the app (default: Person 1, Person 2)
PERSON1_NAME=Alex
PERSON2_NAME=Sam
